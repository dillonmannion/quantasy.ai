# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/tests/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# IDE
.vscode/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.opencode/
# OpenCode/Sisyphus working files
.sisyphus/

# Alternative package managers (project uses pnpm)
bun.lock
yarn.lock

# Generated types (regenerated from schema)
src/lib/supabase/types.generated.ts

# PWA generated files
public/sw.js
public/workbox-*.js
public/*.map
supabase/.temp/

# Development artifacts
data/
scripts/
*.heapsnapshot
git-diagnostics-*.zip
.serena/
