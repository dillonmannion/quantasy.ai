{
  "name": "qai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "corepack": {
    "pnpm": "10.28.1"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate": "pnpm type-check && pnpm lint && pnpm test:run",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:lint": "supabase db lint",
    "types:generate": "supabase gen types typescript --local > src/lib/supabase/types.generated.ts",
    "types:check": "supabase gen types typescript --local | diff -q - src/lib/supabase/types.ts || echo 'Types differ from schema - run pnpm types:generate'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.37.0",
    "@supabase/ssr": "0.8.0",
    "@supabase/supabase-js": "2.93.1",
    "@tanstack/react-virtual": "^3.13.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "groq-sdk": "^0.37.0",
    "lucide-react": "^0.563.0",
    "motion": "12.29.2",
    "next": "16.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.5",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "supabase": "^2.72.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "workspaces": [
    "."
  ]
}
