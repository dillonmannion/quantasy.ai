  "scripts": {
    "dev": "next dev --turbo",
    "dev:mock": "ENABLE_MSW=true next dev --turbo",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate": "pnpm type-check && pnpm lint && pnpm test:run",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "cli": "tsx scripts/cli",
    "visual-qa:discover": "bun tools/visual-qa/discover-routes.ts",
    "visual-qa:setup": "bun tools/visual-qa/setup.ts",
    "visual-qa:auth": "bun tools/visual-qa/authenticate.ts",
    "visual-qa:verify": "bun tools/visual-qa/verify-captures.ts",
    "visual-qa:prompts": "bun tools/visual-qa/generate-prompts.ts",
    "visual-qa:scaffold": "bun tools/visual-qa/scaffold-report.ts",
    "visual-qa": "bun tools/visual-qa/cli.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:lint": "supabase db lint",
    "types:generate": "supabase gen types typescript --local > src/lib/supabase/types.generated.ts",
    "types:check": "supabase gen types typescript --local | diff -q - src/lib/supabase/types.ts || echo 'Types differ from schema - run pnpm types:generate'"
  },
